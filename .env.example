# GitHub personal access token (needs repo read + PR read/write scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# Claude backend: "cli" (default) or "api"
#   cli  — uses the `claude` CLI from Claude Code (works with Pro subscription, no API key needed)
#   api  — uses the Anthropic API (requires ANTHROPIC_API_KEY + paid API credits)
CLAUDE_BACKEND=cli

# Only needed if CLAUDE_BACKEND=api
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-6-20250514

# Application
APP_PORT=8111
APP_HOST=127.0.0.1

# Database path
DB_PATH=./data/reviews.db

# Coherence schedule (cron: minute hour day month weekday)
COHERENCE_CRON=0 9 * * *

# Workspace root (parent dir of all repos)
WORKSPACE_ROOT=/path/to/your/repos
